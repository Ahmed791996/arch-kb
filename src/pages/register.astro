---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sign up">
  <div class="max-w-sm mx-auto px-6 py-20">
    <h1 class="text-2xl font-bold text-white mb-2">Sign up</h1>
    <p class="text-text-muted text-sm mb-8">Start publishing your paths</p>

    <div id="register-error" class="hidden border border-red-500/30 bg-red-500/10 text-red-400 text-sm px-4 py-3 mb-6"></div>

    <!-- Google Sign Up -->
    <button id="google-register" class="btn btn-primary w-full mb-6 py-3">
      <svg width="18" height="18" viewBox="0 0 24 24" class="mr-2">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Sign up with Google
    </button>

    <div class="flex items-center gap-3 mb-6">
      <div class="flex-1 h-px bg-border-primary"></div>
      <span class="text-text-muted text-xs">or create demo account</span>
      <div class="flex-1 h-px bg-border-primary"></div>
    </div>

    <form id="register-form" class="flex flex-col gap-4">
      <div>
        <label class="text-xs text-text-muted uppercase tracking-wider block mb-2">Display name</label>
        <input type="text" name="displayName" class="input" placeholder="Your Name" required />
      </div>
      <div>
        <label class="text-xs text-text-muted uppercase tracking-wider block mb-2">Username</label>
        <input type="text" name="username" class="input" placeholder="username" required autocomplete="username" />
      </div>
      <div>
        <label class="text-xs text-text-muted uppercase tracking-wider block mb-2">Password</label>
        <input type="password" name="password" class="input" placeholder="password" required autocomplete="new-password" />
      </div>
      <div>
        <label class="text-xs text-text-muted uppercase tracking-wider block mb-2">Affiliation</label>
        <input type="text" name="affiliation" class="input" placeholder="SCI-Arc, Studio Name, etc." />
      </div>
      <button type="submit" class="btn mt-2">Create demo account</button>
    </form>

    <p class="text-text-muted text-sm mt-6 text-center">
      Already have an account? <a href="/login" class="text-white underline underline-offset-2">Log in</a>
    </p>
  </div>

  <script>
    import { auth, googleProvider } from '../lib/firebase';
    import { signInWithPopup } from 'firebase/auth';

    document.getElementById('google-register')?.addEventListener('click', async () => {
      const errorEl = document.getElementById('register-error')!;
      try {
        const result = await signInWithPopup(auth, googleProvider);
        const user = result.user;
        const username = user.email?.split('@')[0] || user.uid.slice(0, 10);
        localStorage.setItem('pathkit_user', JSON.stringify({
          username,
          displayName: user.displayName || username,
          email: user.email,
          photo: user.photoURL,
          uid: user.uid,
          provider: 'google',
        }));
        window.location.href = '/explore';
      } catch (err: any) {
        if (err.code === 'auth/configuration-not-found' || err.message?.includes('REPLACE_ME')) {
          errorEl.textContent = 'Firebase not configured yet. Use the form below to create a demo account.';
        } else {
          errorEl.textContent = err.message || 'Registration failed';
        }
        errorEl.classList.remove('hidden');
      }
    });

    document.getElementById('register-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const errorEl = document.getElementById('register-error')!;

      const displayName = (form.displayName as HTMLInputElement).value.trim();
      const username = (form.username as HTMLInputElement).value.trim().toLowerCase().replace(/[^a-z0-9]/g, '');
      const password = (form.password as HTMLInputElement).value;
      const affiliation = (form.affiliation as HTMLInputElement).value.trim();

      if (username.length < 3) { errorEl.textContent = 'Username must be at least 3 characters'; errorEl.classList.remove('hidden'); return; }
      if (password.length < 6) { errorEl.textContent = 'Password must be at least 6 characters'; errorEl.classList.remove('hidden'); return; }

      const registered = JSON.parse(localStorage.getItem('pathkit_registered') || '[]');
      if (registered.find((u: any) => u.username === username)) { errorEl.textContent = 'Username already taken'; errorEl.classList.remove('hidden'); return; }

      registered.push({ username, displayName, password, affiliation });
      localStorage.setItem('pathkit_registered', JSON.stringify(registered));
      localStorage.setItem('pathkit_user', JSON.stringify({ username, displayName }));
      window.location.href = '/explore';
    });
  </script>
</BaseLayout>
