---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { authorToUsername } from '../data/users';

const paths = await getCollection('paths');
const allTools = [...new Set(paths.flatMap((p) => p.data.tools))].sort();
const allDifficulties = ['beginner', 'intermediate', 'advanced'];
const allAuthors = [...new Set(paths.map((p) => p.data.author))].sort();

const difficultyLabel: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// Generate a deterministic hue from a string
function hashHue(str: string): number {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = str.charCodeAt(i) + ((hash << 5) - hash);
  }
  return Math.abs(hash) % 360;
}

// Generate unique gradient per path based on its tools
function pathGradient(tools: string[]): [string, string] {
  const hue1 = hashHue(tools[0] || 'default');
  const hue2 = hashHue(tools[tools.length - 1] || 'default');
  return [
    `hsl(${hue1}, 30%, 8%)`,
    `hsl(${hue2}, 25%, 12%)`,
  ];
}
---

<BaseLayout title="Explore">
  <div class="w-full px-6 py-12">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white">Explore paths</h1>
        <p class="text-text-muted text-sm mt-1">{paths.length} published workflows</p>
      </div>
      <div class="flex items-center gap-3">
        <input type="text" id="search-input" class="input w-64" placeholder="Search paths..." />
        <!-- View toggle -->
        <div class="flex border border-border-primary">
          <button id="view-thumb" class="px-2.5 py-1.5 bg-bg-tertiary border-r border-border-primary hover:bg-bg-elevated transition-colors" title="Thumbnail view">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="1" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="1" y="9" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="9" width="6" height="6" stroke="currentColor" stroke-width="1.5"/></svg>
          </button>
          <button id="view-list" class="px-2.5 py-1.5 hover:bg-bg-elevated transition-colors" title="List view">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="2" width="14" height="2" fill="currentColor"/><rect x="1" y="7" width="14" height="2" fill="currentColor"/><rect x="1" y="12" width="14" height="2" fill="currentColor"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="border border-border-primary bg-bg-secondary p-4 mb-8">
      <div class="flex flex-wrap gap-6">
        <div>
          <div class="text-xs text-text-muted uppercase tracking-wider mb-2">Difficulty</div>
          <div class="flex gap-1">
            <button class="tag filter-btn" data-filter="difficulty" data-value="all">All</button>
            {allDifficulties.map((d) => (
              <button class="tag filter-btn" data-filter="difficulty" data-value={d}>{difficultyLabel[d]}</button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Thumbnail View -->
    <div id="thumb-view" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {paths.map((entry, i) => {
        const grad = pathGradient(entry.data.tools);
        const hue = hashHue(entry.data.tools[0] || 'x');
        const toolCount = entry.data.tools.length;
        const stepCount = entry.data['time-actual'];
        return (
          <div
            class="path-card border border-border-primary bg-bg-secondary hover:border-border-secondary transition-all"
            data-title={entry.data.title.toLowerCase()}
            data-goal={entry.data.goal.toLowerCase()}
            data-difficulty={entry.data.difficulty}
            data-tools={entry.data.tools.join(',')}
            data-author={entry.data.author}
          >
            <a href={`/paths/${entry.id}`} class="block">
              <!-- Thumbnail header -->
              <div
                class="relative h-36 border-b border-border-primary overflow-hidden"
                style={`background: linear-gradient(135deg, ${grad[0]}, ${grad[1]})`}
              >
                {entry.data.thumbnail ? (
                  <img src={entry.data.thumbnail} alt="" class="absolute inset-0 w-full h-full object-cover opacity-60" />
                ) : null}
                {entry.data.icon ? (
                  <div class="absolute top-3 left-3 w-8 h-8 bg-white/10 backdrop-blur-sm border border-white/10 flex items-center justify-center text-lg">
                    {entry.data.icon}
                  </div>
                ) : null}
                <!-- Tool pills floating in thumbnail -->
                <div class="absolute bottom-3 left-3 flex flex-wrap gap-1">
                  {entry.data.tools.map((tool: string) => (
                    <span class="text-[0.6rem] text-white/70 bg-white/10 backdrop-blur-sm px-1.5 py-0.5 border border-white/10">{tool}</span>
                  ))}
                </div>
                <!-- Difficulty badge -->
                <div class="absolute top-3 right-3">
                  <span class="text-[0.6rem] text-white/80 bg-white/10 backdrop-blur-sm px-2 py-0.5 border border-white/10 uppercase tracking-wider">
                    {difficultyLabel[entry.data.difficulty]}
                  </span>
                </div>
                <!-- Decorative accent line -->
                <div class="absolute top-0 left-0 right-0 h-[2px]" style={`background: linear-gradient(90deg, hsl(${hue}, 50%, 40%), transparent)`}></div>
                <!-- Decorative grid pattern -->
                {!entry.data.thumbnail && (
                  <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(0deg, white 0px, white 1px, transparent 1px, transparent 40px), repeating-linear-gradient(90deg, white 0px, white 1px, transparent 1px, transparent 40px);"></div>
                )}
              </div>
              <!-- Card body -->
              <div class="p-4">
                <h3 class="text-white font-semibold text-sm leading-snug">{entry.data.title}</h3>
                <p class="text-text-muted text-xs mt-1.5 line-clamp-2">{entry.data.goal}</p>
                <div class="flex items-center justify-between mt-3 pt-3 border-t border-border-primary text-xs text-text-muted">
                  <span>{entry.data.author}</span>
                  <span>{entry.data.updated} · {entry.data['time-actual']}</span>
                </div>
              </div>
            </a>
          </div>
        );
      })}
    </div>

    <!-- List View -->
    <div id="list-view" class="hidden flex flex-col gap-1">
      {paths.map((entry) => (
        <div
          class="path-card-list border border-border-primary bg-bg-secondary hover:border-border-secondary transition-all"
          data-title={entry.data.title.toLowerCase()}
          data-goal={entry.data.goal.toLowerCase()}
          data-difficulty={entry.data.difficulty}
          data-tools={entry.data.tools.join(',')}
          data-author={entry.data.author}
        >
          <a href={`/paths/${entry.id}`} class="flex items-center gap-4 px-5 py-3">
            <div class="flex-1 min-w-0">
              <h3 class="text-white font-semibold text-sm truncate">{entry.data.title}</h3>
              <p class="text-text-muted text-xs mt-0.5 truncate">{entry.data.goal}</p>
            </div>
            <div class="flex items-center gap-3 shrink-0 text-xs text-text-muted">
              <div class="flex gap-1">
                {entry.data.tools.slice(0, 3).map((tool: string) => (
                  <span class="text-[0.65rem] bg-bg-primary px-1.5 py-0.5 border border-border-primary">{tool}</span>
                ))}
                {entry.data.tools.length > 3 && (
                  <span class="text-[0.65rem]">+{entry.data.tools.length - 3}</span>
                )}
              </div>
              <span class="tag">{difficultyLabel[entry.data.difficulty]}</span>
              <span class="w-20 text-right">{entry.data['time-actual']}</span>
              <span class="w-28 text-right">{entry.data.author}</span>
              <span class="w-16 text-right">{entry.data.updated}</span>
            </div>
          </a>
        </div>
      ))}
    </div>

    <div id="no-results" class="hidden text-center py-16 text-text-muted">
      No paths match your filters.
    </div>
  </div>

  <script is:inline>
    let activeFilters = { difficulty: 'all', tool: 'all', author: 'all' };
    let currentView = localStorage.getItem('archkb_view') || 'thumb';
    const searchInput = document.getElementById('search-input');
    const thumbView = document.getElementById('thumb-view');
    const listView = document.getElementById('list-view');
    const viewThumbBtn = document.getElementById('view-thumb');
    const viewListBtn = document.getElementById('view-list');
    const noResults = document.getElementById('no-results');

    // URL param for tool filter
    const params = new URLSearchParams(window.location.search);
    if (params.get('tool')) {
      activeFilters.tool = params.get('tool');
    }

    function setView(view) {
      currentView = view;
      localStorage.setItem('archkb_view', view);

      if (view === 'thumb') {
        thumbView.classList.remove('hidden');
        listView.classList.add('hidden');
        viewThumbBtn.classList.add('bg-bg-tertiary');
        viewListBtn.classList.remove('bg-bg-tertiary');
      } else {
        thumbView.classList.add('hidden');
        listView.classList.remove('hidden');
        viewListBtn.classList.add('bg-bg-tertiary');
        viewThumbBtn.classList.remove('bg-bg-tertiary');
      }
    }

    function applyFilters() {
      let visible = 0;
      const query = searchInput.value.toLowerCase();

      // Filter both views
      const allCards = document.querySelectorAll('.path-card, .path-card-list');
      allCards.forEach(card => {
        let show = true;
        if (activeFilters.difficulty !== 'all' && card.dataset.difficulty !== activeFilters.difficulty) show = false;
        if (activeFilters.tool !== 'all' && !card.dataset.tools.includes(activeFilters.tool)) show = false;
        if (activeFilters.author !== 'all' && card.dataset.author !== activeFilters.author) show = false;
        if (query && !card.dataset.title.includes(query) && !card.dataset.goal.includes(query)) show = false;

        card.style.display = show ? '' : 'none';
        // Count only from one view to avoid double-counting
        if (show && card.classList.contains('path-card')) visible++;
      });

      noResults.classList.toggle('hidden', visible > 0);

      document.querySelectorAll('.filter-btn').forEach(btn => {
        const isActive = activeFilters[btn.dataset.filter] === btn.dataset.value;
        btn.classList.toggle('tag-active', isActive);
      });
    }

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeFilters[btn.dataset.filter] = btn.dataset.value;
        applyFilters();
      });
    });

    viewThumbBtn.addEventListener('click', () => setView('thumb'));
    viewListBtn.addEventListener('click', () => setView('list'));
    searchInput.addEventListener('input', applyFilters);

    // Init
    setView(currentView);
    applyFilters();
  </script>
</BaseLayout>
