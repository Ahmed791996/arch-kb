---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Log in">
  <div class="max-w-sm mx-auto px-6 py-20">
    <h1 class="text-2xl font-bold text-white mb-2">Log in</h1>
    <p class="text-text-muted text-sm mb-8">Access your path repository</p>

    <div id="login-error" class="hidden border border-red-500/30 bg-red-500/10 text-red-400 text-sm px-4 py-3 mb-6"></div>

    <!-- Google Sign In -->
    <button id="google-login" class="btn btn-primary w-full mb-6 py-3">
      <svg width="18" height="18" viewBox="0 0 24 24" class="mr-2">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Sign in with Google
    </button>

    <div class="flex items-center gap-3 mb-6">
      <div class="flex-1 h-px bg-border-primary"></div>
      <span class="text-text-muted text-xs">or use demo account</span>
      <div class="flex-1 h-px bg-border-primary"></div>
    </div>

    <!-- Demo login -->
    <form id="login-form" class="flex flex-col gap-4">
      <div>
        <label class="text-xs text-text-muted uppercase tracking-wider block mb-2">Username</label>
        <input type="text" name="username" class="input" placeholder="username" required autocomplete="username" />
      </div>
      <div>
        <label class="text-xs text-text-muted uppercase tracking-wider block mb-2">Password</label>
        <input type="password" name="password" class="input" placeholder="password" required autocomplete="current-password" />
      </div>
      <button type="submit" class="btn mt-2">Log in with demo account</button>
    </form>

    <div class="mt-4 border border-border-primary bg-bg-secondary p-3">
      <div class="text-xs text-text-muted mb-1">Demo accounts:</div>
      <div class="text-xs text-text-secondary font-mono">ahmedyakout / admin123</div>
      <div class="text-xs text-text-secondary font-mono">sarahchen / demo123</div>
    </div>

    <p class="text-text-muted text-sm mt-6 text-center">
      No account? <a href="/register" class="text-white underline underline-offset-2">Sign up</a>
    </p>
  </div>

  <script>
    import { auth, googleProvider } from '../lib/firebase';
    import { signInWithPopup } from 'firebase/auth';

    // Google login
    document.getElementById('google-login')?.addEventListener('click', async () => {
      const errorEl = document.getElementById('login-error')!;
      try {
        const result = await signInWithPopup(auth, googleProvider);
        const user = result.user;
        const username = user.email?.split('@')[0] || user.uid.slice(0, 10);
        localStorage.setItem('archkb_user', JSON.stringify({
          username,
          displayName: user.displayName || username,
          email: user.email,
          photo: user.photoURL,
          uid: user.uid,
          provider: 'google',
        }));
        window.location.href = '/explore';
      } catch (err: any) {
        if (err.code === 'auth/configuration-not-found' || err.message?.includes('REPLACE_ME')) {
          errorEl.textContent = 'Firebase not configured yet. Use a demo account below.';
        } else {
          errorEl.textContent = err.message || 'Login failed';
        }
        errorEl.classList.remove('hidden');
      }
    });

    // Demo login
    const users = [
      { username: "ahmedyakout", password: "admin123", displayName: "Ahmed Yakout" },
      { username: "sarahchen", password: "demo123", displayName: "Sarah Chen" },
      { username: "marcorivera", password: "demo123", displayName: "Marco Rivera" },
      { username: "linapark", password: "demo123", displayName: "Lina Park" },
    ];

    document.getElementById('login-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const username = (form.username as HTMLInputElement).value.trim().toLowerCase();
      const password = (form.password as HTMLInputElement).value;
      const errorEl = document.getElementById('login-error')!;

      let user = users.find(u => u.username === username && u.password === password);
      if (!user) {
        const registered = JSON.parse(localStorage.getItem('archkb_registered') || '[]');
        user = registered.find((u: any) => u.username === username && u.password === password);
      }

      if (user) {
        localStorage.setItem('archkb_user', JSON.stringify({
          username: user.username,
          displayName: user.displayName,
        }));
        window.location.href = '/user/' + user.username;
      } else {
        errorEl.textContent = 'Invalid username or password';
        errorEl.classList.remove('hidden');
      }
    });
  </script>
</BaseLayout>
