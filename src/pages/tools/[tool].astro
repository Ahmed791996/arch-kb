---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { authorToUsername } from '../../data/users';

export async function getStaticPaths() {
  const paths = await getCollection('paths');
  const allTools = [...new Set(paths.flatMap((p) => p.data.tools))];
  return allTools.map((tool) => ({
    params: { tool: tool.toLowerCase().replace(/[\s.]+/g, '-') },
    props: {
      toolName: tool,
      toolPaths: paths.filter((p) => p.data.tools.includes(tool)),
    },
  }));
}

const { toolName, toolPaths } = Astro.props;

// Tool descriptions (curated)
const toolDescriptions: Record<string, string> = {
  'COLMAP': 'Structure-from-Motion pipeline for extracting camera positions and sparse point clouds from photo sets. The standard first step for photogrammetry and gaussian splatting workflows.',
  '3DGS': '3D Gaussian Splatting — real-time radiance field rendering. Trains faster than NeRF with comparable quality. Outputs viewable splat files from COLMAP data.',
  'Fal.ai': 'Cloud AI inference platform. Hosts Flux, Stable Diffusion, and custom models via API. Key models for architecture: flux-relight, flux-canny, flux-depth.',
  'Photoshop': 'Adobe Photoshop — final compositing, color grading, and touchup. Used in most paths as the last step before client delivery.',
  'ComfyUI': 'Node-based UI for Stable Diffusion and Flux pipelines. Enables complex multi-model workflows, batch processing, and API-driven automation.',
  'Rhino 8': 'NURBS-based 3D modeling for architecture. Version 8 adds Arctic display mode and improved viewport capture — both critical for AI render pipelines.',
  'ControlNet': 'Conditioning module for diffusion models. Guides image generation using depth maps, line art, canny edges, etc. Essential for preserving architectural geometry in AI renders.',
  'Flux': 'Latest generation image model from Black Forest Labs. Better architectural understanding than SDXL. Supports ControlNet depth and canny conditioning.',
  'Nerfstudio': 'Framework for training and rendering Neural Radiance Fields. Includes COLMAP integration, multiple model architectures, and point cloud export.',
  'CloudCompare': 'Open-source point cloud processing. Used for cleanup, subsampling, outlier removal, and meshing of photogrammetry and NeRF outputs.',
  'Blender': 'Open-source 3D suite. Used for massing models, viewport renders, depth pass export, and EEVEE previews in AI pipelines.',
  'Python': 'Scripting glue for batch automation, ComfyUI API queuing, prompt templating, and Revit interop.',
  'Revit 2024': 'Autodesk BIM software. Used as the final destination for AI-cleaned floor plans and as a source for viewport exports.',
  'Stable Diffusion': 'Open-source image generation model. SDXL recommended for architecture. Best with ControlNet depth guidance for maintaining spatial accuracy.',
  'SketchUp': '3D modeling for architecture. Quick massing and scene setup. Exports depth maps via plugins for AI render pipelines.',
};

const description = toolDescriptions[toolName] || `${toolName} is used in ${toolPaths.length} path${toolPaths.length !== 1 ? 's' : ''} in the pathkit registry.`;

// Related tools (tools that appear in the same paths)
const relatedToolCounts: Record<string, number> = {};
toolPaths.forEach(p => {
  p.data.tools.forEach((t: string) => {
    if (t !== toolName) relatedToolCounts[t] = (relatedToolCounts[t] || 0) + 1;
  });
});
const relatedTools = Object.entries(relatedToolCounts).sort((a, b) => b[1] - a[1]).slice(0, 6);

// Authors who use this tool
const authors = [...new Set(toolPaths.map(p => p.data.author))];

const difficultyLabel: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

const gradients = [
  ['#1a1a2e', '#16213e'],
  ['#1a1a1a', '#2d2d2d'],
  ['#0d1117', '#161b22'],
  ['#1c1c1c', '#2a2a2a'],
  ['#111827', '#1f2937'],
  ['#18181b', '#27272a'],
];
---

<BaseLayout title={toolName} description={`How architects use ${toolName} — ${toolPaths.length} documented workflows`}>
  <div class="w-full px-6 py-12">
    <div class="max-w-4xl">
      <!-- Header -->
      <div class="mb-8 pb-8 border-b border-border-primary">
        <div class="flex items-center gap-3 mb-1">
          <span class="text-xs text-text-muted uppercase tracking-wider">Tool</span>
        </div>
        <h1 class="text-3xl font-bold text-white">{toolName}</h1>
        <p class="text-text-secondary text-sm mt-3 max-w-2xl">{description}</p>
        <div class="flex items-center gap-4 mt-4 text-xs text-text-muted">
          <span>{toolPaths.length} path{toolPaths.length !== 1 ? 's' : ''}</span>
          <span>·</span>
          <span>{authors.length} contributor{authors.length !== 1 ? 's' : ''}</span>
        </div>
      </div>

      <!-- Commonly paired with -->
      {relatedTools.length > 0 && (
        <div class="mb-8">
          <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-3">Commonly paired with</h2>
          <div class="flex flex-wrap gap-2">
            {relatedTools.map(([tool, count]) => (
              <a href={`/tools/${tool.toLowerCase().replace(/[\s.]+/g, '-')}`} class="flex items-center gap-2 border border-border-primary bg-bg-secondary px-3 py-2 hover:border-border-secondary transition-all">
                <span class="text-sm text-white">{tool}</span>
                <span class="text-[0.65rem] text-text-muted">{count}x</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Paths using this tool -->
      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider">Paths using {toolName}</h2>
          <div class="flex border border-border-primary">
            <button id="view-thumb" class="tool-view-btn px-2.5 py-1.5 bg-bg-tertiary border-r border-border-primary hover:bg-bg-elevated transition-colors" title="Thumbnail view">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="1" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="1" y="9" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="9" width="6" height="6" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
            <button id="view-list" class="tool-view-btn px-2.5 py-1.5 hover:bg-bg-elevated transition-colors" title="List view">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="1" y="2" width="14" height="2" fill="currentColor"/><rect x="1" y="7" width="14" height="2" fill="currentColor"/><rect x="1" y="12" width="14" height="2" fill="currentColor"/></svg>
            </button>
          </div>
        </div>

        <!-- Thumbnail view -->
        <div id="thumb-view" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {toolPaths.map((entry, i) => {
            const grad = gradients[i % gradients.length];
            return (
              <a href={`/paths/${entry.id}`} class="block border border-border-primary bg-bg-secondary hover:border-border-secondary transition-all">
                <div class="relative h-32 border-b border-border-primary overflow-hidden" style={`background: linear-gradient(135deg, ${grad[0]}, ${grad[1]})`}>
                  <div class="absolute bottom-3 left-3 flex flex-wrap gap-1">
                    {entry.data.tools.map((t: string) => (
                      <span class:list={["text-[0.6rem] px-1.5 py-0.5 border backdrop-blur-sm", t === toolName ? "text-white bg-white/20 border-white/30" : "text-white/60 bg-white/10 border-white/10"]}>{t}</span>
                    ))}
                  </div>
                  <div class="absolute top-3 right-3">
                    <span class="text-[0.6rem] text-white/80 bg-white/10 backdrop-blur-sm px-2 py-0.5 border border-white/10 uppercase tracking-wider">
                      {difficultyLabel[entry.data.difficulty]}
                    </span>
                  </div>
                  <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(0deg, white 0px, white 1px, transparent 1px, transparent 40px), repeating-linear-gradient(90deg, white 0px, white 1px, transparent 1px, transparent 40px);"></div>
                </div>
                <div class="p-4">
                  <h3 class="text-white font-semibold text-sm leading-snug">{entry.data.title}</h3>
                  <p class="text-text-muted text-xs mt-1.5 line-clamp-2">{entry.data.goal}</p>
                  <div class="flex items-center justify-between mt-3 pt-3 border-t border-border-primary text-xs text-text-muted">
                    <span>{entry.data.author}</span>
                    <span>{entry.data['time-actual']}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <!-- List view -->
        <div id="list-view" class="hidden flex flex-col gap-1">
          {toolPaths.map((entry) => (
            <a href={`/paths/${entry.id}`} class="flex items-center gap-4 border border-border-primary bg-bg-secondary hover:border-border-secondary transition-all px-5 py-3">
              <div class="flex-1 min-w-0">
                <h3 class="text-white font-semibold text-sm truncate">{entry.data.title}</h3>
                <p class="text-text-muted text-xs mt-0.5 truncate">{entry.data.goal}</p>
              </div>
              <div class="flex items-center gap-3 shrink-0 text-xs text-text-muted">
                <span class="tag">{difficultyLabel[entry.data.difficulty]}</span>
                <span class="w-20 text-right">{entry.data['time-actual']}</span>
                <span class="w-28 text-right">{entry.data.author}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const thumbView = document.getElementById('thumb-view');
    const listView = document.getElementById('list-view');
    const viewThumb = document.getElementById('view-thumb');
    const viewList = document.getElementById('view-list');
    let current = localStorage.getItem('pathkit_view') || 'thumb';

    function setView(v) {
      current = v;
      localStorage.setItem('pathkit_view', v);
      thumbView.classList.toggle('hidden', v !== 'thumb');
      listView.classList.toggle('hidden', v !== 'list');
      viewThumb.classList.toggle('bg-bg-tertiary', v === 'thumb');
      viewList.classList.toggle('bg-bg-tertiary', v === 'list');
    }
    viewThumb.addEventListener('click', () => setView('thumb'));
    viewList.addEventListener('click', () => setView('list'));
    setView(current);
  </script>
</BaseLayout>
