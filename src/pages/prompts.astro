---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPaths = await getCollection('paths');

// Extract prompts from all paths (curated data since we can't parse markdown blocks at build time)
const prompts = [
  {
    text: 'a futuristic city at sunset, cyberpunk, neon lights, wide angle, cinematic',
    tool: 'Stable Diffusion',
    use: 'Image generation',
    path: 'ai-image-generator',
    pathTitle: 'Generate AI images with Stable Diffusion locally',
    author: 'Ahmed Yakout',
    tip: 'Be specific about lighting, camera angle, and art style. Avoid vague words like "beautiful".',
  },
  {
    text: 'portrait of an old fisherman, dramatic side lighting, Hasselblad, film grain',
    tool: 'Stable Diffusion',
    use: 'Image generation',
    path: 'ai-image-generator',
    pathTitle: 'Generate AI images with Stable Diffusion locally',
    author: 'Ahmed Yakout',
    tip: 'Naming a specific camera (Hasselblad, Leica, Canon 5D) calibrates the look better than adjectives.',
  },
  {
    text: 'minimalist workspace, clean white desk, morning light, architectural photography',
    tool: 'Stable Diffusion',
    use: 'Image generation',
    path: 'ai-image-generator',
    pathTitle: 'Generate AI images with Stable Diffusion locally',
    author: 'Ahmed Yakout',
    tip: 'Use "[style] photography" as a suffix — e.g., "product photography", "editorial photography", "street photography".',
  },
  {
    text: '[subject], [style keyword], [lighting], [camera/lens], [quality]',
    tool: 'Stable Diffusion',
    use: 'Prompt template',
    path: 'ai-image-generator',
    pathTitle: 'Generate AI images with Stable Diffusion locally',
    author: 'Ahmed Yakout',
    tip: 'This is the universal prompt structure. Fill in each bracket. Never include "best quality", "amazing" — these are noise.',
  },
];

const allTools = [...new Set(prompts.map(p => p.tool))].sort();
const allUses = [...new Set(prompts.map(p => p.use))].sort();
---

<BaseLayout title="Prompt Library">
  <div class="w-full px-6 py-12">
    <div class="max-w-4xl">
      <h1 class="text-2xl font-bold text-white mb-2">Prompt library</h1>
      <p class="text-text-muted text-sm mb-8">Every working prompt extracted from published paths. Copy, adapt, use.</p>

      <!-- Filters -->
      <div class="flex flex-wrap gap-4 mb-8">
        <div>
          <div class="text-xs text-text-muted uppercase tracking-wider mb-2">Tool</div>
          <div class="flex flex-wrap gap-1">
            <button class="tag filter-btn" data-filter="tool" data-value="all">All</button>
            {allTools.map(t => (
              <button class="tag filter-btn" data-filter="tool" data-value={t}>{t}</button>
            ))}
          </div>
        </div>
        <div>
          <div class="text-xs text-text-muted uppercase tracking-wider mb-2">Use case</div>
          <div class="flex flex-wrap gap-1">
            <button class="tag filter-btn" data-filter="use" data-value="all">All</button>
            {allUses.map(u => (
              <button class="tag filter-btn" data-filter="use" data-value={u}>{u}</button>
            ))}
          </div>
        </div>
      </div>

      <!-- Prompts -->
      <div id="prompt-list" class="flex flex-col gap-3">
        {prompts.map((p, i) => (
          <div class="prompt-card border border-border-primary bg-bg-secondary hover:border-border-secondary transition-all" data-tool={p.tool} data-use={p.use}>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-3">
                <span class="tag text-[0.65rem]">{p.tool}</span>
                <span class="tag text-[0.65rem]">{p.use}</span>
              </div>
              <div class="relative group">
                <pre class="bg-bg-primary border border-border-primary p-3 text-sm font-mono text-text-primary overflow-x-auto"><code>{p.text}</code></pre>
                <button class="copy-prompt-btn absolute top-2 right-2 px-2 py-1 text-[0.65rem] bg-bg-tertiary border border-border-primary text-text-muted opacity-0 group-hover:opacity-100 transition-opacity hover:text-white hover:border-border-active" data-text={p.text}>
                  Copy
                </button>
              </div>
              {p.tip && (
                <p class="text-text-muted text-xs mt-2 italic">Tip: {p.tip}</p>
              )}
              <div class="flex items-center justify-between mt-3 pt-2 border-t border-border-primary text-xs text-text-muted">
                <a href={`/paths/${p.path}`} class="hover:text-white transition-colors">From: {p.pathTitle}</a>
                <span>{p.author}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div id="no-prompts" class="hidden text-center py-12 text-text-muted text-sm">
        No prompts match your filters.
      </div>
    </div>
  </div>

  <div id="toast" class="toast"></div>

  <script is:inline>
    let filters = { tool: 'all', use: 'all' };

    function applyFilters() {
      let visible = 0;
      document.querySelectorAll('.prompt-card').forEach(card => {
        let show = true;
        if (filters.tool !== 'all' && card.dataset.tool !== filters.tool) show = false;
        if (filters.use !== 'all' && card.dataset.use !== filters.use) show = false;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      document.getElementById('no-prompts').classList.toggle('hidden', visible > 0);
      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.classList.toggle('tag-active', filters[btn.dataset.filter] === btn.dataset.value);
      });
    }

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        filters[btn.dataset.filter] = btn.dataset.value;
        applyFilters();
      });
    });

    document.querySelectorAll('.copy-prompt-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(btn.dataset.text).then(() => {
          const toast = document.getElementById('toast');
          toast.textContent = 'Prompt copied';
          toast.classList.add('visible');
          setTimeout(() => toast.classList.remove('visible'), 2000);
          btn.textContent = 'Copied';
          setTimeout(() => btn.textContent = 'Copy', 1500);
        });
      });
    });

    applyFilters();
  </script>
</BaseLayout>
