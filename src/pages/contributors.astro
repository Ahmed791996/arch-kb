---
import BaseLayout from '../layouts/BaseLayout.astro';
import { users } from '../data/users';
---

<BaseLayout title="Contributors">
  <div class="w-full px-6 py-12">
    <h1 class="text-2xl font-bold text-white mb-2">Contributors</h1>
    <p class="text-text-muted text-sm mb-8">People publishing their workflows for humans and AI agents</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {users.map((user) => (
        <a
          href={`/user/${user.username}`}
          class="block border border-border-primary bg-bg-secondary p-6 hover:border-border-secondary transition-all"
        >
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-bg-tertiary border border-border-primary flex items-center justify-center text-white font-semibold text-sm shrink-0">
              {user.displayName.split(' ').map(n => n[0]).join('')}
            </div>
            <div class="min-w-0">
              <h3 class="text-white font-semibold text-sm">{user.displayName}</h3>
              <p class="text-text-muted text-xs mt-0.5">{user.role} · {user.affiliation}</p>
              <p class="text-text-secondary text-xs mt-2 line-clamp-2">{user.bio}</p>
              <div class="flex gap-4 mt-3 text-xs text-text-muted">
                <span>{user.pathCount} paths</span>
                <span>Joined {user.joined}</span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
