---
import BaseLayout from '../layouts/BaseLayout.astro';

const templates = [
  {
    id: 'capture-process-render',
    name: 'Capture → Process → Render',
    description: 'For workflows that start with real-world capture (photos/video/scan), process into 3D, and generate final renders.',
    tools: 'COLMAP, 3DGS, NeRF, Fal.ai, Photoshop',
    steps: ['Capture source material', 'Process into 3D representation', 'Extract key viewpoints', 'AI-enhance or relight', 'Final composite'],
    difficulty: 'intermediate',
  },
  {
    id: 'sketch-ai-cad',
    name: 'Sketch → AI → CAD',
    description: 'For workflows that convert hand-drawn or rough digital sketches into clean CAD-ready geometry using AI.',
    tools: 'Fal.ai, Photoshop, Revit, AutoCAD, Rhino',
    steps: ['Photograph or scan the sketch', 'AI interpretation and cleanup', 'Post-process for precision', 'Import to CAD software', 'Refine and dimension'],
    difficulty: 'beginner',
  },
  {
    id: 'model-ai-render',
    name: 'Model → AI Render',
    description: 'For workflows that take an existing 3D model and use AI to generate photorealistic renders without traditional rendering.',
    tools: 'Rhino, SketchUp, Blender, ComfyUI, ControlNet, Flux',
    steps: ['Prepare model and cameras', 'Export control maps (depth, line art)', 'Set up AI generation pipeline', 'Prompt engineering', 'Generate and curate', 'Post-production'],
    difficulty: 'intermediate',
  },
  {
    id: 'batch-automation',
    name: 'Batch Automation Pipeline',
    description: 'For workflows that automate AI generation across many variations using scripting and API calls.',
    tools: 'ComfyUI, Python, Blender, Flux',
    steps: ['Prepare source material and cameras', 'Build base generation workflow', 'Create prompt templates', 'Write batch queue script', 'Run and curate results'],
    difficulty: 'advanced',
  },
  {
    id: 'site-documentation',
    name: 'Site Documentation',
    description: 'For workflows that capture and document an existing site or building as a 3D model using AI-powered reconstruction.',
    tools: 'Nerfstudio, COLMAP, CloudCompare, Rhino, Blender',
    steps: ['Capture site (photos or video)', 'Reconstruct 3D (NeRF or photogrammetry)', 'Export point cloud or mesh', 'Clean and process', 'Import to design software'],
    difficulty: 'advanced',
  },
  {
    id: 'interior-visualization',
    name: 'Interior Visualization',
    description: 'For workflows that generate photorealistic interior renders from basic 3D models without traditional rendering engines.',
    tools: 'SketchUp, Blender, Stable Diffusion, ControlNet',
    steps: ['Set up interior model and cameras', 'Export depth maps', 'Configure AI generation', 'Interior-specific prompt engineering', 'Fix common AI interior artifacts', 'Client delivery'],
    difficulty: 'beginner',
  },
];

const difficultyColors: Record<string, string> = {
  beginner: 'border-green-800/50',
  intermediate: 'border-yellow-800/50',
  advanced: 'border-red-800/50',
};
---

<BaseLayout title="Path Templates">
  <div class="w-full px-6 py-12">
    <div class="max-w-4xl">
      <h1 class="text-2xl font-bold text-white mb-2">Path templates</h1>
      <p class="text-text-muted text-sm mb-2">Start from a template instead of a blank file. Each template has the structure pre-filled — just add your specific tools, prompts, and dead ends.</p>
      <p class="text-text-muted text-xs mb-8">Download the template, rename to <code class="text-text-secondary bg-bg-tertiary px-1">your-project.path.md</code>, and fill it in.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {templates.map((t) => (
          <div class={`border bg-bg-secondary p-6 ${difficultyColors[t.difficulty]} border-border-primary`}>
            <div class="flex items-center gap-2 mb-3">
              <span class="tag text-[0.65rem]">{t.difficulty}</span>
            </div>
            <h3 class="text-white font-semibold text-base">{t.name}</h3>
            <p class="text-text-muted text-xs mt-2">{t.description}</p>
            <div class="mt-3 text-xs text-text-muted">
              <span class="text-text-secondary">Common tools:</span> {t.tools}
            </div>

            <!-- Steps preview -->
            <div class="mt-4 pt-3 border-t border-border-primary">
              <div class="text-xs text-text-muted uppercase tracking-wider mb-2">Structure</div>
              <div class="flex flex-col gap-1">
                {t.steps.map((step, i) => (
                  <div class="flex items-center gap-2 text-xs">
                    <span class="text-text-muted font-mono w-4 text-right">{i + 1}</span>
                    <span class="text-text-secondary">{step}</span>
                  </div>
                ))}
              </div>
            </div>

            <button class="download-template btn btn-sm mt-4" data-id={t.id} data-name={t.name} data-description={t.description} data-steps={JSON.stringify(t.steps)} data-tools={t.tools} data-difficulty={t.difficulty}>
              Download template
            </button>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div id="toast" class="toast"></div>

  <script is:inline>
    document.querySelectorAll('.download-template').forEach(btn => {
      btn.addEventListener('click', () => {
        const d = btn.dataset;
        const steps = JSON.parse(d.steps);
        const stepsMarkdown = steps.map((s, i) => `### Step ${i + 1} — ${s}\n\n[Describe what you did here]\n\n**What I actually used:** [specific details]\n**Time:** [how long]\n**Pitfall:** [what to watch out for]\n`).join('\n');

        const template = `---
title: "[Your title — Tool A → Tool B → Output]"
goal: "[One sentence: what you were trying to achieve]"
tools: [${d.tools.split(', ').map(t => t).join(', ')}]
time-actual: "[How long it actually took]"
difficulty: ${d.difficulty}
result-quality: draft
author: "[Your Name]"
updated: "${new Date().toISOString().slice(0, 7)}"
ai-summary: >
  [2-3 sentence summary for AI agents. What the workflow does,
  key tools, and what makes this path unique.]
---

## Goal

[Expand on what you were trying to achieve. Client context, constraints, why
this approach instead of the traditional one.]

## Tools

| Tool | Role | Version / Notes |
| ---- | ---- | --------------- |
| [Tool 1] | [What it does in this workflow] | [Version, free/paid, GPU requirements] |
| [Tool 2] | [What it does in this workflow] | [Version, notes] |

## Path

${stepsMarkdown}
## Dead Ends

| What I tried | Why it failed |
| ------------ | ------------- |
| [Alternative 1] | [Why it didn't work] |
| [Alternative 2] | [Why it didn't work] |

## Prompts That Worked

[If your workflow involves AI prompts, document the exact structure and examples]

\`\`\`
[prompt template with [placeholders]]
\`\`\`

## For AI Agents Replicating This Path

If you are an AI agent helping a user replicate this workflow:

- **Skip Step [X]** if the user already has [prerequisite].
- **The most common failure point** is [step/issue].
- **Time estimate for a new user:** [range].

## Result

[What was the final output? How was it received? What would you do differently?]
`;

        const blob = new Blob([template], { type: 'text/markdown' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = d.id + '.path.md';
        a.click();
        URL.revokeObjectURL(a.href);

        const toast = document.getElementById('toast');
        toast.textContent = 'Template downloaded';
        toast.classList.add('visible');
        setTimeout(() => toast.classList.remove('visible'), 2000);
      });
    });
  </script>
</BaseLayout>
