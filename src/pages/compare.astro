---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const paths = await getCollection('paths');

// Build comparison data from dead ends and tool usage across paths
const comparisons = [
  {
    id: 'react-vs-vanilla',
    title: 'React vs Vanilla JavaScript',
    toolA: 'React',
    toolB: 'Vanilla JS',
    categories: [
      { label: 'Learning curve', a: 'Moderate (JSX, hooks)', b: 'Low (just JS)', winner: 'b' },
      { label: 'Small projects', a: 'Overkill', b: 'Perfect fit', winner: 'b' },
      { label: 'Large apps', a: 'Scales well (components)', b: 'Gets messy fast', winner: 'a' },
      { label: 'Ecosystem', a: 'Huge (npm, tools)', b: 'You build everything', winner: 'a' },
      { label: 'Performance', a: 'Virtual DOM overhead', b: 'Direct DOM, fast', winner: 'b' },
      { label: 'Best for', a: 'SPAs, dashboards, apps', b: 'Simple pages, scripts', winner: 'tie' },
    ],
    verdict: 'Use vanilla JS for simple projects like calculators. Use React when you need components, state management, and routing.',
    sources: ['calculator-ui', 'react-todo-app'],
  },
  {
    id: 'vercel-vs-railway',
    title: 'Vercel vs Railway for Deployment',
    toolA: 'Vercel',
    toolB: 'Railway',
    categories: [
      { label: 'Frontend apps', a: 'Excellent (optimized)', b: 'Good', winner: 'a' },
      { label: 'Backend/APIs', a: 'Serverless only', b: 'Full server support', winner: 'b' },
      { label: 'Database hosting', a: 'No (use external)', b: 'Yes (Postgres, Redis)', winner: 'b' },
      { label: 'Free tier', a: 'Generous', b: 'Limited ($5 credit)', winner: 'a' },
      { label: 'Deploy speed', a: '< 30 seconds', b: '1-2 minutes', winner: 'a' },
      { label: 'Custom domains', a: 'Free SSL, easy', b: 'Free SSL, easy', winner: 'tie' },
    ],
    verdict: 'Use Vercel for Next.js and frontend apps. Use Railway when you need a database or long-running backend.',
    sources: ['deploy-nextjs-vercel'],
  },
  {
    id: 'local-vs-cloud-ai',
    title: 'Local AI (ComfyUI) vs Cloud AI (Midjourney)',
    toolA: 'ComfyUI (Local)',
    toolB: 'Midjourney (Cloud)',
    categories: [
      { label: 'Cost', a: 'Free (own GPU)', b: '$10-30/month', winner: 'a' },
      { label: 'Setup effort', a: 'High (Python, CUDA)', b: 'None (Discord)', winner: 'b' },
      { label: 'Quality', a: 'Good (model-dependent)', b: 'Excellent', winner: 'b' },
      { label: 'Customization', a: 'Full control (nodes)', b: 'Text prompts only', winner: 'a' },
      { label: 'Batch generation', a: 'Unlimited', b: 'Rate limited', winner: 'a' },
      { label: 'Privacy', a: 'Fully local', b: 'Images on their servers', winner: 'a' },
    ],
    verdict: 'Use Midjourney for quick concepts and mood boards. Use ComfyUI when you need full control, privacy, or batch generation.',
    sources: ['ai-image-generator'],
  },
];
---

<BaseLayout title="Compare Tools">
  <div class="w-full px-6 py-12">
    <div class="max-w-4xl">
      <h1 class="text-2xl font-bold text-white mb-2">Tool comparisons</h1>
      <p class="text-text-muted text-sm mb-8">Side-by-side comparisons pulled from real dead ends and results across paths</p>

      <div class="flex flex-col gap-8">
        {comparisons.map((comp) => (
          <div class="border border-border-primary bg-bg-secondary">
            <div class="p-6 border-b border-border-primary">
              <h2 class="text-white font-bold text-lg">{comp.title}</h2>
              <div class="flex items-center gap-3 mt-2 text-xs text-text-muted">
                <span>Based on {comp.sources.length} paths</span>
                <span>·</span>
                {comp.sources.map(s => (
                  <a href={`/paths/${s}`} class="hover:text-white transition-colors underline underline-offset-2">{s}</a>
                ))}
              </div>
            </div>

            <!-- Comparison table -->
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-border-primary">
                    <th class="text-left text-text-muted font-medium p-4 w-1/3"></th>
                    <th class="text-left text-white font-semibold p-4 w-1/3">{comp.toolA}</th>
                    <th class="text-left text-white font-semibold p-4 w-1/3">{comp.toolB}</th>
                  </tr>
                </thead>
                <tbody>
                  {comp.categories.map((cat) => (
                    <tr class="border-b border-border-primary">
                      <td class="p-4 text-text-muted text-xs">{cat.label}</td>
                      <td class={`p-4 text-xs ${cat.winner === 'a' ? 'text-white font-semibold' : 'text-text-secondary'}`}>
                        {cat.a} {cat.winner === 'a' && '←'}
                      </td>
                      <td class={`p-4 text-xs ${cat.winner === 'b' ? 'text-white font-semibold' : 'text-text-secondary'}`}>
                        {cat.b} {cat.winner === 'b' && '←'}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div class="p-4 bg-bg-primary border-t border-border-primary">
              <div class="text-xs text-text-muted uppercase tracking-wider mb-1">Verdict</div>
              <p class="text-text-secondary text-sm">{comp.verdict}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
