---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { users, authorToUsername } from '../../data/users';

export function getStaticPaths() {
  return users.map((user) => ({
    params: { username: user.username },
    props: { user },
  }));
}

const { user } = Astro.props;
const allPaths = await getCollection('paths');
const userPaths = allPaths.filter((p) => authorToUsername[p.data.author] === user.username);

const difficultyLabel: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

const userTools = [...new Set(userPaths.flatMap((p) => p.data.tools))].sort();

const gradients = [
  ['#1a1a2e', '#16213e'],
  ['#1a1a1a', '#2d2d2d'],
  ['#0d1117', '#161b22'],
  ['#1c1c1c', '#2a2a2a'],
];
---

<BaseLayout title={user.displayName}>
  <div class="w-full px-6 py-12">
    <div class="flex flex-col md:flex-row gap-8">
      <!-- Sidebar -->
      <aside class="md:w-72 shrink-0">
        <div class="border border-border-primary bg-bg-secondary p-6 sticky top-6">
          <div class="w-16 h-16 bg-bg-tertiary border border-border-primary flex items-center justify-center text-white font-bold text-xl mb-4">
            {user.displayName.split(' ').map((n: string) => n[0]).join('')}
          </div>
          <h1 class="text-white font-bold text-lg">{user.displayName}</h1>
          <p class="text-text-muted text-xs mt-1">{user.role}</p>
          <p class="text-text-muted text-xs">{user.affiliation}</p>
          <p class="text-text-secondary text-sm mt-4">{user.bio}</p>

          <button id="follow-btn" class="btn btn-sm w-full mt-4" data-username={user.username} data-name={user.displayName}>
            <span id="follow-text">Follow</span>
          </button>

          <div class="border-t border-border-primary mt-4 pt-4 flex flex-col gap-2 text-xs text-text-muted">
            <div class="flex justify-between"><span>Paths</span><span class="text-white">{userPaths.length}</span></div>
            <div class="flex justify-between"><span>Followers</span><span class="text-white" id="follower-count">0</span></div>
            <div class="flex justify-between"><span>Joined</span><span class="text-white">{user.joined}</span></div>
          </div>

          {userTools.length > 0 && (
            <div class="border-t border-border-primary mt-4 pt-4">
              <div class="text-xs text-text-muted uppercase tracking-wider mb-2">Tools</div>
              <div class="flex flex-wrap gap-1">
                {userTools.map((tool) => (
                  <a href={`/tools/${tool.toLowerCase().replace(/[\s.]+/g, '-')}`} class="tag text-[0.65rem] hover:border-border-active hover:text-white transition-all">{tool}</a>
                ))}
              </div>
            </div>
          )}

          {userPaths.length > 0 && (
            <div class="border-t border-border-primary mt-4 pt-4">
              <div class="text-xs text-text-muted uppercase tracking-wider mb-2">Quick nav</div>
              <nav class="flex flex-col gap-1">
                {userPaths.map((p) => (
                  <a href={`/paths/${p.id}`} class="text-xs text-text-secondary hover:text-white hover:bg-bg-tertiary px-2 py-1.5 transition-all block truncate">{p.data.title}</a>
                ))}
              </nav>
            </div>
          )}
        </div>
      </aside>

      <!-- Main -->
      <div class="flex-1 min-w-0">
        <!-- Tabs -->
        <div class="flex items-center gap-1 mb-6 border-b border-border-primary">
          <button class="profile-tab px-4 py-2 text-sm text-white border-b-2 border-white" data-tab="paths">Paths <span class="text-text-muted ml-1">{userPaths.length}</span></button>
          <button class="profile-tab px-4 py-2 text-sm text-text-muted hover:text-white border-b-2 border-transparent transition-all" data-tab="bookmarks">Bookmarks <span id="bookmark-count" class="ml-1">0</span></button>
        </div>

        <!-- Paths tab -->
        <div id="tab-paths">
          {userPaths.length > 0 && (
            <div class="flex justify-end mb-4">
              <div class="flex border border-border-primary">
                <button id="view-thumb" class="px-2.5 py-1.5 bg-bg-tertiary border-r border-border-primary hover:bg-bg-elevated transition-colors" title="Thumbnails">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="1" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="1" y="9" width="6" height="6" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="9" width="6" height="6" stroke="currentColor" stroke-width="1.5"/></svg>
                </button>
                <button id="view-list" class="px-2.5 py-1.5 hover:bg-bg-elevated transition-colors" title="List">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="1" y="2" width="14" height="2" fill="currentColor"/><rect x="1" y="7" width="14" height="2" fill="currentColor"/><rect x="1" y="12" width="14" height="2" fill="currentColor"/></svg>
                </button>
              </div>
            </div>
          )}

          <!-- Thumbnail view -->
          <div id="thumb-view" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {userPaths.map((entry, i) => {
              const grad = gradients[i % gradients.length];
              return (
                <a href={`/paths/${entry.id}`} class="block border border-border-primary bg-bg-secondary hover:border-border-secondary transition-all">
                  <div class="relative h-32 border-b border-border-primary overflow-hidden" style={`background: linear-gradient(135deg, ${grad[0]}, ${grad[1]})`}>
                    <div class="absolute bottom-3 left-3 flex flex-wrap gap-1">
                      {entry.data.tools.map((t: string) => (
                        <span class="text-[0.6rem] text-white/70 bg-white/10 backdrop-blur-sm px-1.5 py-0.5 border border-white/10">{t}</span>
                      ))}
                    </div>
                    <div class="absolute top-3 right-3">
                      <span class="text-[0.6rem] text-white/80 bg-white/10 backdrop-blur-sm px-2 py-0.5 border border-white/10 uppercase tracking-wider">{difficultyLabel[entry.data.difficulty]}</span>
                    </div>
                    <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(0deg, white 0px, white 1px, transparent 1px, transparent 40px), repeating-linear-gradient(90deg, white 0px, white 1px, transparent 1px, transparent 40px);"></div>
                  </div>
                  <div class="p-4">
                    <h3 class="text-white font-semibold text-sm leading-snug">{entry.data.title}</h3>
                    <p class="text-text-muted text-xs mt-1.5 line-clamp-2">{entry.data.goal}</p>
                    <div class="flex items-center justify-between mt-3 pt-3 border-t border-border-primary text-xs text-text-muted">
                      <span>{entry.data['time-actual']}</span>
                      <span>{entry.data.updated}</span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>

          <!-- List view -->
          <div id="list-view" class="hidden flex flex-col gap-3">
            {userPaths.map((entry) => (
              <div class="border border-border-primary bg-bg-secondary hover:border-border-secondary transition-all">
                <a href={`/paths/${entry.id}`} class="block p-5">
                  <div class="flex items-start justify-between gap-4">
                    <div class="min-w-0">
                      <h3 class="text-white font-semibold text-sm">{entry.data.title}</h3>
                      <p class="text-text-muted text-xs mt-1">{entry.data.goal}</p>
                    </div>
                    <span class="tag shrink-0">{difficultyLabel[entry.data.difficulty]}</span>
                  </div>
                  <div class="flex flex-wrap gap-1 mt-3">
                    {entry.data.tools.map((tool: string) => (
                      <span class="text-[0.65rem] text-text-muted bg-bg-primary px-1.5 py-0.5 border border-border-primary">{tool}</span>
                    ))}
                  </div>
                  <div class="flex items-center gap-4 mt-3 pt-3 border-t border-border-primary text-xs text-text-muted">
                    <span>Updated {entry.data.updated}</span>
                    <span>{entry.data['time-actual']}</span>
                    <span>{entry.data['result-quality']}</span>
                  </div>
                </a>
              </div>
            ))}
          </div>

          {userPaths.length === 0 && (
            <div class="border border-border-primary bg-bg-secondary p-12 text-center">
              <p class="text-text-muted text-sm">No paths published yet.</p>
            </div>
          )}
        </div>

        <!-- Bookmarks tab -->
        <div id="tab-bookmarks" class="hidden">
          <div id="bookmarks-list"></div>
          <div id="no-bookmarks" class="border border-border-primary bg-bg-secondary p-12 text-center">
            <p class="text-text-muted text-sm">No bookmarked paths yet.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // Tabs
    document.querySelectorAll('.profile-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.profile-tab').forEach(t => { t.classList.remove('text-white', 'border-white'); t.classList.add('text-text-muted', 'border-transparent'); });
        tab.classList.remove('text-text-muted', 'border-transparent');
        tab.classList.add('text-white', 'border-white');
        document.getElementById('tab-paths').classList.toggle('hidden', tab.dataset.tab !== 'paths');
        document.getElementById('tab-bookmarks').classList.toggle('hidden', tab.dataset.tab !== 'bookmarks');
      });
    });

    // View toggle
    const thumbView = document.getElementById('thumb-view');
    const listView = document.getElementById('list-view');
    const vt = document.getElementById('view-thumb');
    const vl = document.getElementById('view-list');
    let cv = localStorage.getItem('pathkit_view') || 'thumb';
    function sv(v) { cv=v; localStorage.setItem('pathkit_view',v); thumbView?.classList.toggle('hidden',v!=='thumb'); listView?.classList.toggle('hidden',v!=='list'); vt?.classList.toggle('bg-bg-tertiary',v==='thumb'); vl?.classList.toggle('bg-bg-tertiary',v==='list'); }
    vt?.addEventListener('click', ()=>sv('thumb'));
    vl?.addEventListener('click', ()=>sv('list'));
    sv(cv);

    // Follow
    const followBtn = document.getElementById('follow-btn');
    const followText = document.getElementById('follow-text');
    const followerCount = document.getElementById('follower-count');
    function getFollowing() { return JSON.parse(localStorage.getItem('pathkit_following') || '[]'); }
    function getFollowers(u) { return JSON.parse(localStorage.getItem('pathkit_followers_' + u) || '0'); }
    function updateFollowUI() {
      const username = followBtn?.dataset.username;
      const following = getFollowing();
      const isFollowing = following.includes(username);
      if (isFollowing) { followText.textContent = 'Following'; followBtn.classList.add('btn-primary'); }
      else { followText.textContent = 'Follow'; followBtn.classList.remove('btn-primary'); }
      followerCount.textContent = getFollowers(username);
    }
    followBtn?.addEventListener('click', () => {
      const username = followBtn.dataset.username;
      let following = getFollowing();
      let count = parseInt(getFollowers(username));
      if (following.includes(username)) {
        following = following.filter(u => u !== username);
        count = Math.max(0, count - 1);
      } else {
        following.push(username);
        count++;
        // Add notification
        const notifs = JSON.parse(localStorage.getItem('pathkit_notifs') || '[]');
        const user = JSON.parse(localStorage.getItem('pathkit_user') || '{}');
        notifs.unshift({ text: `You followed ${followBtn.dataset.name}`, date: new Date().toISOString(), read: false });
        localStorage.setItem('pathkit_notifs', JSON.stringify(notifs));
      }
      localStorage.setItem('pathkit_following', JSON.stringify(following));
      localStorage.setItem('pathkit_followers_' + username, count);
      updateFollowUI();
    });
    updateFollowUI();

    // Bookmarks
    const bookmarks = JSON.parse(localStorage.getItem('pathkit_bookmarks') || '[]');
    document.getElementById('bookmark-count').textContent = bookmarks.length;
    const bl = document.getElementById('bookmarks-list');
    const nb = document.getElementById('no-bookmarks');
    if (bookmarks.length > 0) {
      nb.classList.add('hidden');
      bl.innerHTML = bookmarks.map(b => `<div class="border border-border-primary bg-bg-secondary hover:border-border-secondary transition-all mb-2"><a href="/paths/${b.slug}" class="flex items-center justify-between p-4"><div><h3 class="text-white font-semibold text-sm">${b.title}</h3><span class="text-text-muted text-[0.65rem]">Saved ${new Date(b.date).toLocaleDateString('en-US',{month:'short',day:'numeric'})}</span></div><span class="text-text-muted text-xs">→</span></a></div>`).join('');
    }
  </script>
</BaseLayout>
