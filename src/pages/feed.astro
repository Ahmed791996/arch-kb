---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { authorToUsername, users } from '../data/users';

const paths = await getCollection('paths');
const sorted = [...paths].sort((a, b) => b.data.updated.localeCompare(a.data.updated));

// Simulate activity feed entries
const feedItems = sorted.flatMap((p) => {
  const username = authorToUsername[p.data.author];
  return [
    { type: 'published', author: p.data.author, username, title: p.data.title, slug: p.id, date: p.data.updated + '-15', tools: p.data.tools },
  ];
}).sort((a, b) => b.date.localeCompare(a.date));

const difficultyLabel: Record<string, string> = { beginner: 'Beginner', intermediate: 'Intermediate', advanced: 'Advanced' };
---

<BaseLayout title="Activity Feed" adminOnly={true}>
  <div class="w-full px-6 py-12">
    <div class="max-w-2xl">
      <h1 class="text-2xl font-bold text-white mb-2">Activity feed</h1>
      <p class="text-text-muted text-sm mb-8">Recent activity across the platform</p>

      <div id="feed-list" class="flex flex-col gap-3">
        {feedItems.map((item) => (
          <div class="border border-border-primary bg-bg-secondary p-4 hover:border-border-secondary transition-all">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-bg-tertiary border border-border-primary flex items-center justify-center text-white font-semibold text-xs shrink-0 mt-0.5">
                {item.author.split(' ').map(n => n[0]).join('')}
              </div>
              <div class="min-w-0 flex-1">
                <div class="text-sm">
                  <a href={`/user/${item.username}`} class="text-white font-semibold hover:opacity-80">{item.author}</a>
                  <span class="text-text-muted"> published a new path</span>
                </div>
                <a href={`/paths/${item.slug}`} class="block mt-2 border border-border-primary bg-bg-primary p-3 hover:border-border-secondary transition-all">
                  <h3 class="text-white font-semibold text-sm">{item.title}</h3>
                  <div class="flex flex-wrap gap-1 mt-2">
                    {item.tools.slice(0, 4).map((t: string) => (
                      <span class="text-[0.6rem] text-text-muted bg-bg-tertiary px-1.5 py-0.5 border border-border-primary">{t}</span>
                    ))}
                  </div>
                </a>
                <div class="text-[0.65rem] text-text-muted mt-2">{item.date}</div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Client-side activity (from localStorage) -->
      <div id="local-activity" class="mt-6">
        <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">Your activity</h2>
        <div id="local-feed"></div>
      </div>
    </div>
  </div>

  <script is:inline>
    const localFeed = document.getElementById('local-feed');
    const bookmarks = JSON.parse(localStorage.getItem('pathkit_bookmarks') || '[]');
    const upvotes = JSON.parse(localStorage.getItem('pathkit_user_upvotes') || '[]');

    const items = [
      ...bookmarks.map(b => ({ type: 'bookmark', text: `Bookmarked "${b.title}"`, date: b.date, url: '/paths/' + b.slug })),
      ...upvotes.map(u => ({ type: 'upvote', text: `Upvoted "${u}"`, date: new Date().toISOString(), url: '/paths/' + u })),
    ].sort((a, b) => b.date.localeCompare(a.date)).slice(0, 10);

    if (items.length === 0) {
      localFeed.innerHTML = '<div class="border border-border-primary bg-bg-secondary p-6 text-center text-text-muted text-sm">No activity yet. Bookmark or upvote paths to see them here.</div>';
    } else {
      localFeed.innerHTML = items.map(i => `
        <a href="${i.url}" class="block border border-border-primary bg-bg-secondary p-3 mb-2 hover:border-border-secondary transition-all">
          <div class="text-sm text-text-secondary">${i.text}</div>
          <div class="text-[0.6rem] text-text-muted mt-1">${new Date(i.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</div>
        </a>
      `).join('');
    }
  </script>
</BaseLayout>
