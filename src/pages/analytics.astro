---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { users, authorToUsername } from '../data/users';

const paths = await getCollection('paths');

// Stats
const totalPaths = paths.length;
const totalTools = [...new Set(paths.flatMap(p => p.data.tools))].length;
const totalAuthors = [...new Set(paths.map(p => p.data.author))].length;

// By difficulty
const byDifficulty = { beginner: 0, intermediate: 0, advanced: 0 };
paths.forEach(p => byDifficulty[p.data.difficulty]++);

// By quality
const byQuality: Record<string, number> = {};
paths.forEach(p => { byQuality[p.data['result-quality']] = (byQuality[p.data['result-quality']] || 0) + 1; });

// Tool frequency
const toolCounts: Record<string, number> = {};
paths.forEach(p => p.data.tools.forEach((t: string) => { toolCounts[t] = (toolCounts[t] || 0) + 1; }));
const topTools = Object.entries(toolCounts).sort((a, b) => b[1] - a[1]);

// Author frequency
const authorCounts: Record<string, number> = {};
paths.forEach(p => { authorCounts[p.data.author] = (authorCounts[p.data.author] || 0) + 1; });

// Tool pairs (which tools are used together)
const toolPairs: Record<string, number> = {};
paths.forEach(p => {
  const tools = p.data.tools;
  for (let i = 0; i < tools.length; i++) {
    for (let j = i + 1; j < tools.length; j++) {
      const pair = [tools[i], tools[j]].sort().join(' + ');
      toolPairs[pair] = (toolPairs[pair] || 0) + 1;
    }
  }
});
const topPairs = Object.entries(toolPairs).sort((a, b) => b[1] - a[1]).slice(0, 10);

const diffLabel: Record<string, string> = { beginner: 'Beginner', intermediate: 'Intermediate', advanced: 'Advanced' };
---

<BaseLayout title="Analytics" adminOnly={true}>
  <div class="w-full px-6 py-12">
    <div class="max-w-5xl">
      <h1 class="text-2xl font-bold text-white mb-2">Analytics</h1>
      <p class="text-text-muted text-sm mb-8">Registry-wide stats and insights</p>

      <!-- Overview -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
        <div class="border border-border-primary bg-bg-secondary p-5">
          <div class="text-3xl font-bold text-white">{totalPaths}</div>
          <div class="text-xs text-text-muted mt-1">Total paths</div>
        </div>
        <div class="border border-border-primary bg-bg-secondary p-5">
          <div class="text-3xl font-bold text-white">{totalTools}</div>
          <div class="text-xs text-text-muted mt-1">Unique tools</div>
        </div>
        <div class="border border-border-primary bg-bg-secondary p-5">
          <div class="text-3xl font-bold text-white">{totalAuthors}</div>
          <div class="text-xs text-text-muted mt-1">Contributors</div>
        </div>
        <div class="border border-border-primary bg-bg-secondary p-5">
          <div class="text-3xl font-bold text-white" id="total-upvotes">0</div>
          <div class="text-xs text-text-muted mt-1">Total upvotes</div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Difficulty distribution -->
        <div>
          <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">By difficulty</h2>
          <div class="flex flex-col gap-3">
            {Object.entries(byDifficulty).map(([d, count]) => (
              <div>
                <div class="flex justify-between text-sm mb-1">
                  <span class="text-text-secondary">{diffLabel[d]}</span>
                  <span class="text-white font-semibold">{count}</span>
                </div>
                <div class="h-2 bg-bg-tertiary">
                  <div class="h-full bg-border-secondary" style={`width: ${(count / totalPaths) * 100}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Result quality -->
        <div>
          <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">By result quality</h2>
          <div class="flex flex-col gap-3">
            {Object.entries(byQuality).map(([q, count]) => (
              <div>
                <div class="flex justify-between text-sm mb-1">
                  <span class="text-text-secondary">{q}</span>
                  <span class="text-white font-semibold">{count}</span>
                </div>
                <div class="h-2 bg-bg-tertiary">
                  <div class="h-full bg-border-secondary" style={`width: ${(count / totalPaths) * 100}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- All tools ranked -->
        <div>
          <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">Tool frequency</h2>
          <div class="flex flex-col gap-2">
            {topTools.map(([tool, count]) => (
              <a href={`/tools/${tool.toLowerCase().replace(/[\s.]+/g, '-')}`} class="flex items-center gap-3 group">
                <div class="flex-1">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-text-secondary group-hover:text-white transition-colors">{tool}</span>
                    <span class="text-xs text-text-muted">{count}</span>
                  </div>
                  <div class="mt-1 h-1 bg-bg-tertiary">
                    <div class="h-full bg-border-secondary group-hover:bg-border-active transition-colors" style={`width: ${(count / topTools[0][1]) * 100}%`}></div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Tool pairs -->
        <div>
          <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">Common tool pairs</h2>
          <div class="flex flex-col gap-2">
            {topPairs.map(([pair, count]) => (
              <div class="flex items-center justify-between border border-border-primary bg-bg-secondary px-4 py-2">
                <span class="text-sm text-text-secondary">{pair}</span>
                <span class="text-xs text-text-muted">{count}x</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Paths per author -->
        <div>
          <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">Paths per contributor</h2>
          <div class="flex flex-col gap-2">
            {Object.entries(authorCounts).sort((a, b) => b[1] - a[1]).map(([author, count]) => (
              <a href={`/user/${authorToUsername[author]}`} class="flex items-center justify-between border border-border-primary bg-bg-secondary px-4 py-2 hover:border-border-secondary transition-all">
                <span class="text-sm text-text-secondary hover:text-white">{author}</span>
                <span class="text-white font-semibold text-sm">{count}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Downloads & interactions (client-side) -->
        <div>
          <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">Your interactions</h2>
          <div class="flex flex-col gap-3">
            <div class="flex justify-between border border-border-primary bg-bg-secondary px-4 py-3">
              <span class="text-text-secondary text-sm">Bookmarks</span>
              <span id="stat-bookmarks" class="text-white font-semibold">0</span>
            </div>
            <div class="flex justify-between border border-border-primary bg-bg-secondary px-4 py-3">
              <span class="text-text-secondary text-sm">Upvotes given</span>
              <span id="stat-upvotes" class="text-white font-semibold">0</span>
            </div>
            <div class="flex justify-between border border-border-primary bg-bg-secondary px-4 py-3">
              <span class="text-text-secondary text-sm">Notes posted</span>
              <span id="stat-notes" class="text-white font-semibold">0</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const bookmarks = JSON.parse(localStorage.getItem('archkb_bookmarks') || '[]');
    const upvotes = JSON.parse(localStorage.getItem('archkb_user_upvotes') || '[]');
    const allUpvotes = JSON.parse(localStorage.getItem('archkb_upvotes') || '{}');
    const totalUps = Object.values(allUpvotes).reduce((a, b) => a + b, 0);

    document.getElementById('stat-bookmarks').textContent = bookmarks.length;
    document.getElementById('stat-upvotes').textContent = upvotes.length;
    document.getElementById('total-upvotes').textContent = totalUps;

    // Count notes across all paths
    let noteCount = 0;
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i);
      if (key?.startsWith('archkb_comments_')) {
        noteCount += JSON.parse(localStorage.getItem(key) || '[]').length;
      }
    }
    document.getElementById('stat-notes').textContent = noteCount;
  </script>
</BaseLayout>
