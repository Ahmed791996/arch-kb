---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { authorToUsername } from '../data/users';

const allPaths = await getCollection('paths');

// Sort by updated date (most recent first)
const sorted = [...allPaths].sort((a, b) => b.data.updated.localeCompare(a.data.updated));

// Group by month
const grouped: Record<string, typeof allPaths> = {};
sorted.forEach((p) => {
  const key = p.data.updated;
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(p);
});

const difficultyLabel: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// Stats
const totalPaths = allPaths.length;
const totalTools = [...new Set(allPaths.flatMap((p) => p.data.tools))].length;
const totalAuthors = [...new Set(allPaths.map((p) => p.data.author))].length;

// Most used tools
const toolCounts: Record<string, number> = {};
allPaths.forEach(p => p.data.tools.forEach((t: string) => {
  toolCounts[t] = (toolCounts[t] || 0) + 1;
}));
const topTools = Object.entries(toolCounts).sort((a, b) => b[1] - a[1]).slice(0, 8);
---

<BaseLayout title="This Week">
  <div class="w-full px-6 py-12">
    <div class="max-w-3xl">
      <h1 class="text-2xl font-bold text-white mb-2">This week on pathkit</h1>
      <p class="text-text-muted text-sm mb-8">Recent paths, trends, and registry stats</p>

      <!-- Quick stats -->
      <div class="grid grid-cols-4 gap-3 mb-10">
        <div class="border border-border-primary bg-bg-secondary p-4">
          <div class="text-xl font-bold text-white">{totalPaths}</div>
          <div class="text-xs text-text-muted mt-1">Total paths</div>
        </div>
        <div class="border border-border-primary bg-bg-secondary p-4">
          <div class="text-xl font-bold text-white">{totalTools}</div>
          <div class="text-xs text-text-muted mt-1">Tools indexed</div>
        </div>
        <div class="border border-border-primary bg-bg-secondary p-4">
          <div class="text-xl font-bold text-white">{totalAuthors}</div>
          <div class="text-xs text-text-muted mt-1">Contributors</div>
        </div>
        <div class="border border-border-primary bg-bg-secondary p-4">
          <div class="text-xl font-bold text-white">{sorted[0]?.data.updated || '—'}</div>
          <div class="text-xs text-text-muted mt-1">Latest update</div>
        </div>
      </div>

      <!-- Trending tools -->
      <div class="mb-10">
        <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">Most used tools</h2>
        <div class="flex flex-col gap-2">
          {topTools.map(([tool, count]) => (
            <a href={`/explore?tool=${encodeURIComponent(tool)}`} class="flex items-center gap-3 group">
              <div class="flex-1">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-text-secondary group-hover:text-white transition-colors">{tool}</span>
                  <span class="text-xs text-text-muted">{count} path{count !== 1 ? 's' : ''}</span>
                </div>
                <div class="mt-1 h-1 bg-bg-tertiary">
                  <div class="h-full bg-border-secondary group-hover:bg-border-active transition-colors" style={`width: ${(count / topTools[0][1]) * 100}%`}></div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Timeline -->
      <div>
        <h2 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">Timeline</h2>
        {Object.entries(grouped).map(([date, paths]) => (
          <div class="mb-8">
            <div class="text-xs text-text-muted font-mono mb-3 pl-4 border-l-2 border-border-secondary">{date}</div>
            <div class="flex flex-col gap-2 pl-4 border-l-2 border-border-primary">
              {paths.map((entry) => (
                <a href={`/paths/${entry.id}`} class="block border border-border-primary bg-bg-secondary p-4 hover:border-border-secondary transition-all ml-4">
                  <div class="flex items-start justify-between gap-4">
                    <div class="min-w-0">
                      <h3 class="text-white font-semibold text-sm">{entry.data.title}</h3>
                      <p class="text-text-muted text-xs mt-1">{entry.data.goal}</p>
                      <div class="flex items-center gap-2 mt-2 text-xs text-text-muted">
                        <span>{entry.data.author}</span>
                        <span>·</span>
                        <span class="tag text-[0.65rem]">{difficultyLabel[entry.data.difficulty]}</span>
                      </div>
                    </div>
                    <div class="flex flex-wrap gap-1 shrink-0 max-w-32">
                      {entry.data.tools.slice(0, 3).map((tool: string) => (
                        <span class="text-[0.6rem] text-text-muted bg-bg-primary px-1 py-0.5 border border-border-primary">{tool}</span>
                      ))}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
